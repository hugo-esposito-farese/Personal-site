---
interface Props {
  id: string;
  title: string;
  date: Date;
  tags: string[];
  excerpt?: string;
}

const { id, title, date, tags, excerpt } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group">
  <a href={`/journal/${id}`} class="block py-5 border-b border-zinc-800/60 hover:border-zinc-700 transition-colors">
    <div class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-6">
      <time
        datetime={date.toISOString()}
        class="text-sm text-zinc-600 shrink-0 pt-0.5 font-mono w-28"
      >
        {formatted}
      </time>
      <div class="flex-1 min-w-0">
        <h3 class="font-medium text-zinc-200 group-hover:text-white transition-colors mb-1 leading-snug">
          {title}
        </h3>
        {excerpt && (
          <p class="text-sm text-zinc-500 leading-relaxed line-clamp-2">{excerpt}</p>
        )}
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-2">
            {tags.map((tag) => (
              <span class="text-xs text-zinc-600 font-mono">#{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </a>
</article>
