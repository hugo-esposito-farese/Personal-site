---
import Base from '../layouts/Base.astro';
import StatusBadge from '../components/StatusBadge.astro';
import Tag from '../components/Tag.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort(
  (a, b) => b.data.startDate.getTime() - a.data.startDate.getTime()
);
---

<Base title="Hugo Esposito-Farese">
  <div class="lg:flex min-h-screen">

    <!-- Left: identity panel -->
    <aside
      class="lg:w-72 xl:w-80 shrink-0 lg:sticky lg:top-0 lg:h-screen lg:overflow-y-auto
             border-b border-zinc-800/60 lg:border-b-0 lg:border-r lg:border-zinc-800/60
             px-8 py-10 flex flex-col gap-8"
    >
      <!-- Avatar + identity -->
      <div>
        <img
          src="/images/hugo_photo_42.jpg"
          alt="Hugo Esposito-Farese"
          class="w-40 h-40 md:w-56 md:h-56 rounded-full object-cover"
          width="64"
          height="64"
        />
        <h1 class="text-base font-bold text-zinc-50 tracking-tight leading-snug mb-2">
          Hugo Esposito-Farese
        </h1>
        <p class="text-sm text-zinc-400 leading-relaxed">
          Computer Science student @ 42 Paris building software and early-stage products
        </p>
      </div>

      <!-- Social links -->
      <nav class="flex flex-col gap-0.5">
        <a
          href= "https://github.com/hugo-esposito-farese"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2.5 text-sm text-zinc-500 hover:text-zinc-200 transition-colors px-2 py-1.5 rounded-md hover:bg-zinc-900"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="shrink-0">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          GitHub
        </a>
        <a
          href="https://fr.linkedin.com/in/hugo-esposito-farese-530045407"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2.5 text-sm text-zinc-500 hover:text-zinc-200 transition-colors px-2 py-1.5 rounded-md hover:bg-zinc-900"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="shrink-0">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          LinkedIn
        </a>
        <a
          href="https://x.com"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2.5 text-sm text-zinc-500 hover:text-zinc-200 transition-colors px-2 py-1.5 rounded-md hover:bg-zinc-900"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="shrink-0">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          X / Twitter
        </a>
      </nav>

    </aside>

    <!-- Right: project feed -->
    <main class="flex-1 min-w-0 px-6 py-10 lg:px-10">
      <div class="max-w-3xl">
        <p class="text-xs font-medium text-zinc-600 uppercase tracking-widest mb-6">
          Projects &mdash; {projects.length}
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {projects.map((project) => {
            const links = project.data.links;
            const href = links?.live ?? links?.github ?? `/projects/${project.id}`;
            const isExternal = !!(links?.live ?? links?.github);

            return (
              <a
                href={href}
                target={isExternal ? '_blank' : undefined}
                rel={isExternal ? 'noopener noreferrer' : undefined}
                class="group flex flex-col gap-3 bg-zinc-900/50 border border-zinc-800/80 rounded-xl p-5
                       hover:border-zinc-700 hover:bg-zinc-900 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/30
                       transition-all duration-150"
              >
                <div class="flex items-start justify-between gap-3">
                  <div class="flex items-center gap-2 min-w-0">
                    {project.data.logo && (
                      <img
                        src={project.data.logo}
                        alt=""
                        width="18"
                        height="18"
                        class="w-[18px] h-[18px] shrink-0 rounded object-contain"
                      />
                    )}
                    <span class="font-semibold text-sm text-zinc-100 group-hover:text-white transition-colors leading-snug truncate">
                      {project.data.title}
                    </span>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    {project.data.revenue && (
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-medium
                                   bg-emerald-500/8 text-emerald-400 border border-emerald-500/15 whitespace-nowrap">
                        {project.data.revenue}
                      </span>
                    )}
                    <StatusBadge status={project.data.status} />
                  </div>
                </div>

                <p class="text-xs text-zinc-500 leading-relaxed line-clamp-2 flex-1">
                  {project.data.description}
                </p>

                {project.data.technologies.length > 0 && (
                  <div class="flex flex-wrap gap-1">
                    {project.data.technologies.slice(0, 4).map((tech) => (
                      <Tag tag={tech} />
                    ))}
                    {project.data.technologies.length > 4 && (
                      <span class="text-xs text-zinc-700 self-center">
                        +{project.data.technologies.length - 4}
                      </span>
                    )}
                  </div>
                )}
              </a>
            );
          })}
        </div>
      </div>
    </main>

  </div>
</Base>
