---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404 — Not Found">
  <div class="max-w-3xl mx-auto px-6 py-32 text-center">
    <p class="text-6xl font-bold text-zinc-800 mb-4">404</p>
    <h1 class="text-xl font-semibold text-zinc-300 mb-3">Page not found</h1>
    <p class="text-zinc-500 mb-8">This page doesn't exist — or it used to and I moved it.</p>
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-zinc-200 border border-zinc-800 rounded-lg px-4 py-2 transition-colors hover:border-zinc-700"
    >
      Back home
    </a>
  </div>
</PageLayout>
